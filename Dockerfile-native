# syntax=docker/dockerfile:1
#
# Multi-stage Dockerfile for a GraalVM native image of the BootUI sample app.
#
# BootUI is a multi-module Maven project, so the whole reactor is copied into
# the build stage and the sample app is built together with the modules it
# depends on (`-pl bootui-sample-app -am`).
#
# For a JVM image see Dockerfile, for a JVM image using CRaC see Dockerfile-crac.
#
# Requires GraalVM 25+ for Spring Boot 4 (GraalVM 25 = JDK 25).
#
# The image runs with the "dev" Spring profile, which is baked in at *build time*: a native
# image freezes auto-configuration during AOT, so the profile is activated by the `native`
# profile's process-aot step in bootui-sample-app/pom.xml (not via a runtime env var). It starts
# Docker-free on an in-memory H2 database with BootUI enabled.
#
# For a faster startup the sample database migrations are disabled by default, also at build time
# (process-aot sets -Dspring.flyway.enabled=false -Dspring.liquibase.enabled=false in
# bootui-sample-app/pom.xml). Unlike the JVM and CRaC images this cannot be toggled with a runtime
# env var, because AOT freezes auto-configuration; to populate the BootUI Flyway/Liquibase panels,
# rebuild the image with those two flags removed from the process-aot <jvmArguments>.
#
# Build and run:
#   docker build -f Dockerfile-native -t bootui-sample-app-native .
#   docker run --rm -p 8080:8080 -e BOOTUI_TRUST_CONTAINER_GATEWAY=AUTO bootui-sample-app-native
#   # then open http://localhost:8080/bootui

# Build stage with GraalVM 25 (includes the native-image toolchain, JDK 25)
FROM ghcr.io/graalvm/graalvm-community:25 AS build

WORKDIR /app

# Copy the whole multi-module project (see .dockerignore for exclusions).
COPY . .
RUN chmod +x mvnw

# Build a "mostly static" native image: statically link everything (including zlib) except glibc,
# so the runtime image only needs a glibc base and no extra shared libraries. The native-image tool
# honors this via the NATIVE_IMAGE_OPTIONS environment variable, so it needs no pom changes and does
# not affect a local, host `-Pnative` build. The GraalVM build image already ships the static zlib
# (libz.a) this requires.
ENV NATIVE_IMAGE_OPTIONS="-H:+StaticExecutableWithDynamicLibC"

# Build the native executable for the sample app and its reactor dependencies.
# The `native` profile (declared in bootui-sample-app/pom.xml) runs Spring
# Boot's process-aot goal, downloads GraalVM reachability metadata and then
# compiles the native image during the `package` phase (build-native).
#
# The Maven local repository (~/.m2, which also caches the frontend-maven-plugin's
# Node.js/npm archive downloads under com/github/eirslett) and the npm package
# cache (~/.npm) are kept in BuildKit cache mounts so they are reused across
# rebuilds rather than re-downloaded every time. (The native-image compilation
# itself is not cached.) These caches live in the builder, not in the image, and
# require BuildKit, the default in modern Docker. The GraalVM build image runs as
# root, so the Maven/npm home is /root.
RUN --mount=type=cache,target=/root/.m2 \
    --mount=type=cache,target=/root/.npm \
    ./mvnw -Pnative -DskipTests -pl bootui-sample-app -am clean package

# Move the native executable to a known path (the native-maven-plugin names it
# after the module artifactId, i.e. bootui-sample-app).
RUN if [ -f bootui-sample-app/target/bootui-sample-app ]; then \
      cp bootui-sample-app/target/bootui-sample-app native-app; \
    else \
      native_exe=$(find bootui-sample-app/target -maxdepth 1 -type f -executable ! -name '*.jar' ! -name '*.jar.original' | head -1) && \
      if [ -n "$native_exe" ]; then cp "$native_exe" native-app; \
      else echo "ERROR: Native executable not found"; ls -laR bootui-sample-app/target | head -40; exit 1; fi; \
    fi

# Runtime stage: Google "distroless" base. It ships glibc (and the dynamic loader) but no shell,
# package manager, curl, perl or tar - which removes the bulk of the OS-package CVEs that a full
# Debian base otherwise carries (those are unfixed upstream and cannot be patched away). The native
# binary above is built "mostly static", so glibc is the only shared library it needs and this base
# provides it. The :nonroot tag runs as an unprivileged user (uid 65532).
FROM gcr.io/distroless/base-debian12:nonroot

WORKDIR /app

# Copy the native executable from the build stage
COPY --from=build --chown=nonroot:nonroot /app/native-app native-app

USER nonroot

EXPOSE 8080

# No Docker HEALTHCHECK: the distroless base has no shell or curl to run a probe. Probe the web
# server (or /actuator/health) from your orchestrator's liveness/readiness checks instead.

# Run the native application
ENTRYPOINT ["./native-app"]
