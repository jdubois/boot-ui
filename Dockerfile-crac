# syntax=docker/dockerfile:1
#
# Multi-stage Dockerfile for a CRaC (Coordinated Restore at Checkpoint) image of
# the BootUI sample app.
#
# CRaC snapshots a fully warmed-up JVM process to disk and restores it in tens of
# milliseconds. It only works on Linux and needs a CRaC-enabled JDK plus elevated
# container privileges (CRIU) to take and restore the checkpoint - see
# docker-compose-crac.yml and bootui-spring-sample-app/README.md.
#
# The sample app runs with its default "dev" profile, which uses an in-memory H2
# database (and an in-memory cache) instead of PostgreSQL/Redis, so the checkpoint
# is taken with no open network sockets and restores cleanly out of the box. See
# the README for the (more involved) external-services variant. For a faster
# startup the sample database migrations are disabled by default (see below).
#
# BootUI is a multi-module Maven project, so the whole reactor is copied into the
# build stage and the sample app is built together with the modules it depends on
# (`-pl bootui-spring-sample-app -am`). For a JVM image see Dockerfile, for a GraalVM
# native image see Dockerfile-native.
#
# Build and run (CRIU needs extra privileges; the named volume keeps the checkpoint
# between restarts, and -p publishes the port so the app is reachable from the host):
#
#   docker build -f Dockerfile-crac -t bootui-sample-app-crac .
#   docker run --rm -p 8080:8080 \
#     --cap-add=CHECKPOINT_RESTORE --cap-add=SYS_PTRACE --cap-add=SYS_ADMIN \
#     -e BOOTUI_TRUST_CONTAINER_GATEWAY=AUTO \
#     -v bootui-sample-app-crac:/opt/crac/checkpoint bootui-sample-app-crac
#   # then open http://localhost:8080/bootui
#
# Or use docker-compose-crac.yml (docker compose -f docker-compose-crac.yml up --build).
#
# Enable the sample database migrations (to populate the BootUI Flyway/Liquibase panels):
# The sample app can apply two pending Flyway migrations and two Liquibase change sets on startup
# so those panels have data to show. They are off by default for a faster boot; turn them back on
# with Spring Boot's environment variables on the run that takes the checkpoint (they are frozen
# into it):
#   docker run --rm -p 8080:8080 \
#     --cap-add=CHECKPOINT_RESTORE --cap-add=SYS_PTRACE --cap-add=SYS_ADMIN \
#     -e BOOTUI_TRUST_CONTAINER_GATEWAY=AUTO \
#     -e SPRING_FLYWAY_ENABLED=true -e SPRING_LIQUIBASE_ENABLED=true \
#     -v bootui-sample-app-crac:/opt/crac/checkpoint bootui-sample-app-crac

# Build stage (a plain JDK is enough; CRaC only matters at runtime).
FROM eclipse-temurin:21-jdk-noble AS build

WORKDIR /app

# Copy the whole multi-module project (see .dockerignore for exclusions).
COPY . .
RUN chmod +x mvnw

# Build the sample app and its reactor dependencies. The sample app binds the
# spring-boot-maven-plugin "repackage" goal, so this produces a runnable Spring
# Boot jar (with BOOT-INF and a Main-Class) alongside the thin *.jar.original.
#
# The Maven local repository (~/.m2, which also caches the frontend-maven-plugin's
# Node.js/npm archive downloads under com/github/eirslett) and the npm package
# cache (~/.npm) are kept in BuildKit cache mounts so they are reused across
# rebuilds rather than re-downloaded every time. These caches live in the builder,
# not in the image. (Requires BuildKit, the default in modern Docker.)
RUN --mount=type=cache,target=/root/.m2 \
    --mount=type=cache,target=/root/.npm \
    ./mvnw -Pcrac -DskipTests -pl bootui-spring-sample-app -am clean package

# Runtime stage with a CRaC-enabled JDK (BellSoft Liberica with CRaC support).
FROM bellsoft/liberica-runtime-container:jdk-21-crac-slim-glibc

WORKDIR /app

# Where the checkpoint image is written/read. Mounted as a volume in
# docker-compose-crac.yml so the checkpoint survives container restarts.
ENV CRAC_CHECKPOINT_DIR=/opt/crac/checkpoint
ENV APP_JAR=/app/app.jar

# Run the sample app with its "dev" profile *active* (not merely the default).
# BootUI's activation condition checks Environment.getActiveProfiles(), which does
# NOT include profiles set only via spring.profiles.default. Without an active
# profile (and with devtools stripped from the repackaged jar) BootUI would stay
# disabled in the container. CRaC freezes this into the checkpoint at first start,
# so it must be set before the checkpoint is taken - hence baking it in here.
ENV SPRING_PROFILES_ACTIVE=dev

# Disable the sample Flyway/Liquibase migrations by default for a faster startup; the checkpoint is
# taken with them off. Re-enable them with -e SPRING_FLYWAY_ENABLED=true -e
# SPRING_LIQUIBASE_ENABLED=true on the run that takes the checkpoint to populate the BootUI
# Flyway/Liquibase panels.
ENV SPRING_FLYWAY_ENABLED=false
ENV SPRING_LIQUIBASE_ENABLED=false

# JVM tuning flags, applied by checkpoint-and-run.sh when the checkpoint is created (the first start)
# and frozen into the CRaC image - a restore replays that JVM, so heap/GC flags cannot be changed on
# a restore-only start. Mirrors the JVM image (Dockerfile) minus -XX:+UseCompactObjectHeaders, which
# was introduced in JDK 24 and is unsupported here: BellSoft ships CRaC-enabled Liberica only for the
# LTS releases (17 and 21), so this image stays on JDK 21. Override (and regenerate the checkpoint)
# with -e JAVA_OPTS="...".
ENV JAVA_OPTS="-Xms200m -Xmx200m -XX:MaxMetaspaceSize=171m -XX:ReservedCodeCacheSize=240m -XX:MaxDirectMemorySize=10m -Xss512k -XX:+AlwaysPreTouch -XX:+UseG1GC -XX:+UseStringDeduplication -XX:+ExitOnOutOfMemoryError -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/tmp"

# Copy the repackaged, runnable Spring Boot jar (the glob skips the thin
# *.jar.original) and the checkpoint/restore entrypoint.
COPY --from=build /app/bootui-spring-sample-app/target/bootui-spring-sample-app-*.jar ${APP_JAR}
COPY --from=build /app/bootui-spring-sample-app/src/main/script/checkpoint-and-run.sh /app/checkpoint-and-run.sh

RUN chmod +x /app/checkpoint-and-run.sh && mkdir -p ${CRAC_CHECKPOINT_DIR}

EXPOSE 8080

# Take a checkpoint on the first start, then restore on every start.
ENTRYPOINT ["/app/checkpoint-and-run.sh"]
