{
  "name": "bootui-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "posttest": "node scripts/normalize-coverage-paths.mjs",
    "test:watch": "vitest",
    "preview": "vite preview",
    "format": "prettier --config ../../../../prettier.config.cjs --ignore-path ../../../../.prettierignore --write .",
    "format:check": "prettier --config ../../../../prettier.config.cjs --ignore-path ../../../../.prettierignore --check ."
  },
  "dependencies": {
    "bootstrap": "5.3.8",
    "bootstrap-icons": "1.13.1",
    "vue": "3.5.35",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/coverage-v8": "4.1.8",
    "@vue/server-renderer": "3.5.35",
    "@vue/test-utils": "2.4.10",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}
